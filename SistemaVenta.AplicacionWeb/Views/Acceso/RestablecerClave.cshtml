@model SistemaVenta.AplicacionWeb.Models.ViewModels.VMUsuarioLogin
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>Mi Tienda - Restablecer Clave</title>

    <!-- Custom fonts for this template-->
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet">

    <!-- Custom styles for this template-->
    <link href="~/css/sb-admin-2.css" rel="stylesheet">
    <link href="~/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">

    <style>
        body {
            min-height: 100vh;
        }

        .center-container {
            border-radius: 10px;
            width: 800px; /* ancho */
            max-width: 90%;
            text-align: center;
        }
    </style>

</head>

<body class="bg-gradient-info d-flex justify-content-center align-items-center">

    <div class="container center-container">

        <div class="card o-hidden border-0 shadow-lg">
            <div class="card-body p-0">

                <div class="row">
                    <div class="col-12">
                        <div class="p-5">
                            <div class="text-center">
                                <h1 class="h4 text-gray-900 mb-2">¿Olvidó su contraseña?</h1>
                                <p class="mb-4">Ingrese su correo de sesión y le enviaremos una nueva contraseña</p>
                            </div>

                            <form class="user" asp-controller="Acceso" asp-action="RestablecerClave" method="post">
                                <div class="form-group">
                                    <input type="email" class="form-control form-control-user" asp-for="Correo" placeholder="Ingrese su correo">
                                </div>

                                @if (ViewData["Mensaje"] != null)
                                {
                                    <div class="form-group">
                                        <div class="alert alert-success" role="alert">
                                            @ViewData["Mensaje"]
                                        </div>
                                    </div>
                                }

                                @if (ViewData["MensajeError"] != null)
                                {
                                    <div class="form-group">
                                        <div class="alert alert-danger" role="alert">
                                            @ViewData["MensajeError"]
                                        </div>
                                    </div>
                                }

                                <button type="submit" class="btn btn-primary btn-user btn-block">
                                    Restablecer Contraseña
                                </button>
                            </form>

                            <hr>
                            <div class="text-center">
                                <a class="small" href="@Url.Action("Login", "Acceso")">Iniciar Sesión</a>
                            </div>

                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>

</body>

</html>

